{
  "name": "@hham21/circe",
  "version": "0.5.4",
  "description": "Composable multi-agent orchestration framework built on the Claude Agent SDK",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "circe": "dist/cli/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hham21/circe.git"
  },
  "keywords": [
    "claude",
    "agent",
    "multi-agent",
    "orchestration",
    "ai",
    "anthropic",
    "claude-code",
    "agent-sdk",
    "pipeline",
    "harness",
    "agent-harness"
  ],
  "license": "MIT",
  "homepage": "https://github.com/hham21/circe#readme",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "lint:examples": "tsc -p tsconfig.examples.json"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
